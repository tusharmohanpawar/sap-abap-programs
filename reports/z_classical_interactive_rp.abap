REPORT ZFEBCLASSICAL_INTERACTIVE.

TABLES: MARA,MAKT.

TYPES: BEGIN OF STR_MARA,
        MATNR TYPE MARA-MATNR,
        ERNAM TYPE MARA-ERNAM,
        MTART TYPE MARA-MTART,
        MBRSH TYPE MARA-MBRSH,
        MATKL TYPE MARA-MATKL,
      END OF STR_MARA.

TYPES: BEGIN OF STR_MAKT,
        MATNR TYPE MAKT-MATNR,
        SPRAS TYPE MAKT-SPRAS,
        MAKTX TYPE MAKT-MAKTX,
      END OF STR_MAKT.


DATA: IT_MARA TYPE TABLE OF STR_MARA,
      WA_MARA TYPE STR_MARA,
      IT_MAKT TYPE TABLE OF STR_MAKT,
      WA_MAKT TYPE STR_MAKT.

SELECT-OPTIONS: P_MATNR FOR MARA-MATNR.

TOP-OF-PAGE.
WRITE: 'MATERIAL NO',
       30 'USER NO',
       40 'MAT TYPE',
       60 'IND SECT',
       70 'MAT GRUP'.

ULINE.

TOP-OF-PAGE DURING LINE-SELECTION.
WRITE: 'MATERIAL NO',
       30 'LANG',
       60 'DISCRIPTION'.

START-OF-SELECTION.
SELECT
  MATNR
  ERNAM
  MTART
  MBRSH
  MATKL
  FROM MARA INTO TABLE IT_MARA
  WHERE MATNR IN P_MATNR.

  LOOP AT IT_MARA INTO WA_MARA.
    WRITE:/ WA_MARA-MATNR,
          30 WA_MARA-ERNAM,
          40 WA_MARA-MTART,
          60 WA_MARA-MBRSH,
          70 WA_MARA-MATKL.
     HIDE WA_MARA.
  ENDLOOP.

 AT LINE-SELECTION.
   CASE SY-LSIND.
     WHEN 1.
  SELECT
     MATNR
     SPRAS
     MAKTX
     FROM MAKT INTO TABLE IT_MAKT
     WHERE MATNR = WA_MARA-MATNR.

    LOOP AT IT_MAKT INTO WA_MAKT.
      WRITE:/ WA_MAKT-MATNR,
            30 WA_MAKT-SPRAS,
            60 WA_MAKT-MAKTX.
    ENDLOOP.
    WHEN 2.
      WRITE: 'NEXT SCREEN IS PROCESSD, THANK YOU'.
  ENDCASE.
