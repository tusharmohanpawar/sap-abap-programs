REPORT ZFEB_BAPI.
*include bdcrecx1_s.

TYPES: BEGIN OF STR_MARA,
       MATNR TYPE MARA-MATNR,
       MBRSH TYPE MARA-MBRSH,
       MTART TYPE MARA-MTART,
       MAKTX TYPE MAKT-MAKTX,
       MEINS TYPE MARA-MEINS,
       MATKL TYPE MARA-MATKL,
       BRGEW TYPE MARA-BRGEW,
       GEWEI TYPE MARA-GEWEI,
       NTGEW TYPE MARA-NTGEW,
  END OF STR_MARA.

DATA: IT_MARA TYPE TABLE OF STR_MARA,
      WA_MARA TYPE STR_MARA,
      RAW_DATA TYPE TRUXS_T_TEXT_DATA.

DATA:   BDCDATA LIKE BDCDATA    OCCURS 0 WITH HEADER LINE.
*       messages of call transaction
DATA:   MESSTAB LIKE BDCMSGCOLL OCCURS 0 WITH HEADER LINE.

PARAMETERS: P_FILE TYPE RLGRAP-FILENAME.

AT SELECTION-SCREEN ON VALUE-REQUEST FOR P_FILE.


CALL FUNCTION 'F4_FILENAME'
 EXPORTING
    PROGRAM_NAME        = SYST-CPROG
*   DYNPRO_NUMBER       = SYST-DYNNR
*   FIELD_NAME          = ' '
 IMPORTING
   FILE_NAME           = P_FILE
          .

CALL FUNCTION 'TEXT_CONVERT_XLS_TO_SAP'
  EXPORTING
*   I_FIELD_SEPERATOR          = I_FIELD_SEPERATOR
    I_LINE_HEADER              = 'X'
    I_TAB_RAW_DATA             = RAW_DATA
    I_FILENAME                 = P_FILE
  TABLES
    I_TAB_CONVERTED_DATA       = IT_MARA
* EXCEPTIONS
*   CONVERSION_FAILED          = 1
*   OTHERS                     = 2
          .
IF SY-SUBRC <> 0.
* Implement suitable error handling here
ENDIF.


start-of-selection.

DATA: WA_HEADDATA TYPE BAPIMATHEAD,
      WA_CLIENTDATA TYPE BAPI_MARA,
      WA_CLIENTDATAX TYPE BAPI_MARAX,

      RETURN TYPE BAPIRET2,

      IT_MAT TYPE TABLE OF BAPI_MAKT,
      WA_MAT TYPE BAPI_MAKT,
      IT_UNIT TYPE TABLE OF BAPI_MARM,
      WA_UNIT TYPE BAPI_MARM,
      IT_UNITX TYPE TABLE OF BAPI_MARMX,
      WA_UNITX TYPE BAPI_MARMX,
      IT_RETURN TYPE TABLE OF BAPI_MATRETURN2,
      WA_RETURN TYPE BAPI_MATRETURN2.


LOOP AT IT_MARA INTO WA_MARA.

WA_HEADDATA-MATERIAL = WA_MARA-MATNR.
WA_HEADDATA-IND_SECTOR = WA_MARA-MBRSH.
WA_HEADDATA-MATL_TYPE = WA_MARA-MTART.
WA_HEADDATA-BASIC_VIEW = 'X'.

WA_CLIENTDATA-MATL_GROUP = WA_MARA-MATKL.
WA_CLIENTDATA-BASE_UOM   = WA_MARA-MEINS.
WA_CLIENTDATA-NET_WEIGHT = WA_MARA-NTGEW.
WA_CLIENTDATA-UNIT_OF_WT = WA_MARA-GEWEI.
WA_CLIENTDATA-UNIT_OF_WT_ISO = WA_MARA-GEWEI.

WA_CLIENTDATAX-MATL_GROUP = 'X'.
WA_CLIENTDATAX-BASE_UOM   = 'X'.
WA_CLIENTDATAX-NET_WEIGHT = 'X'.
WA_CLIENTDATAX-UNIT_OF_WT = 'X'.
WA_CLIENTDATAX-UNIT_OF_WT_ISO = 'X'.

WA_MAT-LANGU = SY-LANGU.
WA_MAT-MATL_DESC = WA_MARA-MAKTX.
APPEND WA_MAT TO IT_MAT.

WA_UNIT-ALT_UNIT = WA_MARA-MEINS.
WA_UNIT-GROSS_WT = WA_MARA-BRGEW.
WA_UNIT-UNIT_OF_WT = WA_MARA-GEWEI.
WA_UNIT-UNIT_OF_WT_ISO = WA_MARA-GEWEI.
APPEND WA_UNIT TO IT_UNIT.

WA_UNITX-ALT_UNIT = WA_MARA-MEINS.
WA_UNITX-GROSS_WT = 'X'.
WA_UNITX-UNIT_OF_WT = 'X'.
WA_UNITX-UNIT_OF_WT_ISO = 'X'.
APPEND WA_UNITX TO IT_UNITX.


CALL FUNCTION 'BAPI_MATERIAL_SAVEDATA'
  EXPORTING
    HEADDATA                  = WA_HEADDATA
   CLIENTDATA                 = WA_CLIENTDATA
   CLIENTDATAX                = WA_CLIENTDATAX
 IMPORTING
   RETURN                     = RETURN
 TABLES
   MATERIALDESCRIPTION        = IT_MAT
   UNITSOFMEASURE             = IT_UNIT
   UNITSOFMEASUREX            = IT_UNITX
   RETURNMESSAGES             = IT_RETURN
          .
 WRITE: / RETURN-MESSAGE.
 WRITE: / RETURN-MESSAGE_V1.

CLEAR: WA_HEADDATA,WA_CLIENTDATA,WA_CLIENTDATAX,WA_MAT,WA_UNIT,WA_UNITX,WA_MARA.
REFRESH: IT_MAT,IT_MARA,IT_UNIT,IT_UNITX,IT_RETURN.

ENDLOOP.
